-- Serviços
local Workspace = game:GetService("Workspace")

-- Variável de controle
local distanceEnabled = false

-- Função para interagir com o NPC FakeIDSeller de longe
local function interactFakeIDSeller()
    local npc = Workspace.Folders.NPCs:FindFirstChild("FakeIDSeller")
    if npc then
        local torso = npc:FindFirstChild("UpperTorso")
        if torso then
            local att = torso:FindFirstChild("Attachment")
            local pp = att and att:FindFirstChild("ProximityPrompt")
            if pp then
                if distanceEnabled then
                    pp.MaxActivationDistance = 9999 -- aumenta distância
                else
                    pp.MaxActivationDistance = 10 -- valor padrão
                end
            end
        end
    end
end

-- Carregar Kavo UI
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("XFC AutoFarm", "DarkTheme")

-- Aba Fake ID
local TabFakeID = Window:NewTab("Fake ID")
local SectionFakeID = TabFakeID:NewSection("Controle")

-- Toggle para aumentar distância de interação
SectionFakeID:NewToggle("Interagir de longe", "Permite comprar Fake IDs sem estar perto", function(state)
    distanceEnabled = state
    interactFakeIDSeller()
end)
