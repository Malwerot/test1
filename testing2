-- Serviços
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- Variáveis locais
local fakeIDCount = 0
local maxFakeIDs = 2
local selectedAmount = 1
local fakeIDLabel
local autoBuy = false
local autoBuyConnection

-- Função para comprar Fake IDs
local function buyFakeIDs(amount)
    local npc = Workspace.Folders.NPCs:FindFirstChild("FakeIDSeller")
    if npc then
        local torso = npc:FindFirstChild("UpperTorso")
        if torso then
            local att = torso:FindFirstChild("Attachment")
            local pp = att and att:FindFirstChild("ProximityPrompt")
            if pp then
                for i = 1, amount do
                    if fakeIDCount < maxFakeIDs then
                        fireproximityprompt(pp)
                        fakeIDCount = fakeIDCount + 1
                        fakeIDLabel:UpdateLabel("🪪 Fake IDs: "..fakeIDCount.."/"..maxFakeIDs)
                        task.wait(0.2)
                    end
                end
            end
        end
    end
end

-- Carregar Kavo UI
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("XFC AutoFarm", "DarkTheme")

-- Aba Fake ID
local TabFakeID = Window:NewTab("Fake ID")
local SectionFakeID = TabFakeID:NewSection("Controle")

-- Label único
fakeIDLabel = SectionFakeID:NewLabel("🪪 Fake IDs: "..fakeIDCount.."/"..maxFakeIDs)

-- Slider para escolher quantidade
SectionFakeID:NewSlider("Quantidade", "Quantos Fake IDs comprar", 1, maxFakeIDs, 1, function(val)
    selectedAmount = val
end)

-- Botão para comprar
SectionFakeID:NewButton("Comprar Fake IDs", "Compra a quantidade escolhida", function()
    buyFakeIDs(selectedAmount)
end)

-- Toggle para compra automática
SectionFakeID:NewToggle("AutoBuy Fake IDs", "Compra automaticamente em loop", function(state)
    autoBuy = state
    if state then
        if autoBuyConnection then autoBuyConnection:Disconnect() end
        autoBuyConnection = RunService.Heartbeat:Connect(function()
            if autoBuy then
                buyFakeIDs(1)
            end
        end)
    else
        if autoBuyConnection then
            autoBuyConnection:Disconnect()
            autoBuyConnection = nil
        end
    end
end)
