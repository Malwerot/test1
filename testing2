-- Serviços
local Workspace = game:GetService("Workspace")

-- Variáveis de controle
local distanceEnabledFakeID = false
local forceInteractionFakeID = false
local distanceEnabledBank = false
local forceInteractionBank = false

-- Função para interagir com o NPC FakeIDSeller
local function interactFakeIDSeller()
    local npc = Workspace.Folders.NPCs:FindFirstChild("FakeIDSeller")
    if npc then
        local torso = npc:FindFirstChild("UpperTorso")
        if torso then
            local att = torso:FindFirstChild("Attachment")
            local pp = att and att:FindFirstChild("ProximityPrompt")
            if pp then
                -- Ajusta distância
                if distanceEnabledFakeID then
                    pp.MaxActivationDistance = 9999
                else
                    pp.MaxActivationDistance = 10
                end

                -- Força prompt aparecer mesmo em animação
                pp.RequiresLineOfSight = false
                pp.Enabled = true

                -- Se toggle estiver ligado, dispara interação
                if forceInteractionFakeID then
                    fireproximityprompt(pp)
                end
            end
        end
    end
end

-- Função para interagir com o NPC Bank Teller
local function interactBankTeller()
    local npc = Workspace.Folders.NPCs:FindFirstChild("Bank Teller")
    if npc then
        local torso = npc:FindFirstChild("UpperTorso")
        if torso then
            local att = torso:FindFirstChild("Attachment")
            local pp = att and att:FindFirstChild("ProximityPrompt")
            if pp then
                -- Ajusta distância
                if distanceEnabledBank then
                    pp.MaxActivationDistance = 9999
                else
                    pp.MaxActivationDistance = 10
                end

                -- Força prompt aparecer mesmo em animação
                pp.RequiresLineOfSight = false
                pp.Enabled = true

                -- Se toggle estiver ligado, dispara interação
                if forceInteractionBank then
                    fireproximityprompt(pp)
                end
            end
        end
    end
end

-- Carregar Kavo UI
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("XFC AutoFarm", "DarkTheme")

-- Aba Fake ID
local TabFakeID = Window:NewTab("Fake ID")
local SectionFakeID = TabFakeID:NewSection("Controle")

SectionFakeID:NewToggle("Interagir de longe", "Permite comprar Fake IDs sem estar perto", function(state)
    distanceEnabledFakeID = state
    interactFakeIDSeller()
end)

SectionFakeID:NewToggle("Forçar Interação", "NPC reage mesmo durante animação", function(state)
    forceInteractionFakeID = state
    interactFakeIDSeller()
end)

-- Aba Bank Teller
local TabBank = Window:NewTab("Bank Teller")
local SectionBank = TabBank:NewSection("Controle")

SectionBank:NewToggle("Interagir de longe", "Permite falar com o Bank Teller sem estar perto", function(state)
    distanceEnabledBank = state
    interactBankTeller()
end)

SectionBank:NewToggle("Forçar Interação", "NPC reage mesmo durante animação", function(state)
    forceInteractionBank = state
    interactBankTeller()
end)
