-- Serviços
local Workspace = game:GetService("Workspace")

-- Função para interagir com o NPC FakeIDSeller de longe
local function buyFakeIDFromDistance()
    local npc = Workspace.Folders.NPCs:FindFirstChild("FakeIDSeller")
    if npc then
        local torso = npc:FindFirstChild("UpperTorso")
        if torso then
            local att = torso:FindFirstChild("Attachment")
            local pp = att and att:FindFirstChild("ProximityPrompt")
            if pp then
                -- aumenta a distância máxima para interagir
                pp.MaxActivationDistance = 9999
                -- dispara o prompt mesmo sem estar perto
                fireproximityprompt(pp)
            end
        end
    end
end

-- Exemplo de uso: botão na UI
SectionFakeID:NewButton("Comprar de longe", "Compra Fake ID sem precisar chegar perto", function()
    buyFakeIDFromDistance()
end)
